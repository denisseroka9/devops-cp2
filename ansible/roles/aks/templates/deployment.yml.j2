apiVersion: apps/v1
kind: Deployment
metadata:
  name: webk8s-deployment
  namespace: web-k8s
spec:
  replicas: 1
  selector:
    matchLabels:
      app: webk8s
  template:
    metadata:
      labels:
        app: webk8s
    spec:
      containers:
      - name: webk8s
        image: acrcp2denisse.azurecr.io/webk8s:casopractico2
        ports:
        - containerPort: 6379